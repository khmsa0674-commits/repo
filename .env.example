# ─────────────────────────────────────────────────────────────
#  ملف إعدادات البوت — انسخه إلى .env واملأ البيانات
# ─────────────────────────────────────────────────────────────

# 🤖 توكن البوت من @BotFather
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# 👑 معرفات الأدمن (أرقام مفصولة بفاصلة)
# يمكنك الحصول على معرفك من @userinfobot
ADMIN_IDS=123456789,987654321

# 🏷 اسم البوت
BOT_NAME=VidBot Pro

# 📦 الحد الأقصى لحجم الملف بـ MB (الحد الأقصى للتليكرام 50MB)
MAX_FILE_SIZE_MB=49

# ⏱ مهلة التحميل بالثواني
DOWNLOAD_TIMEOUT=120

# 🗄 مسار قاعدة البيانات
DATABASE_PATH=bot_database.db
